# HubSpot Private App のアクセストークン（サーバー側でのみ使用）
# Vercel の Project Settings → Environment Variables に設定すること。
# コードに直書きしない。
HUBSPOT_TOKEN=

# ---------- Supabase ----------
# Supabase ダッシュボード → Project Settings → API から取得。
# NEXT_PUBLIC_ 付きはブラウザに出てOK（公開前提のキー）。
# service_role は全権限。NEXT_PUBLIC_ を付けず、サーバー専用にすること。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
